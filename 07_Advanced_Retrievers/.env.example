# Copy this file to .env and fill in your keys.
# .env is gitignored so your secrets won't be committed.

# Required API keys
OPENAI_API_KEY=your-openai-key
COHERE_API_KEY=your-cohere-key

# LangSmith tracing
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=your-langsmith-key
LANGSMITH_PROJECT=aim-session-7-advanced-retrievers

# Optional model overrides
AIM_CHAT_MODEL=gpt-5.4-mini
AIM_EVAL_MODEL=gpt-5.4-mini
AIM_EMBEDDING_MODEL=text-embedding-3-small
AIM_RERANK_MODEL=rerank-v4.0-fast
