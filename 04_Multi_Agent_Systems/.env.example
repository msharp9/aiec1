# Copy this file to .env and fill in your keys.
# .env is gitignored so your secrets won't be committed.

# Required API keys
OPENAI_API_KEY=
TAVILY_API_KEY=

# Optional LangSmith tracing
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=aim-session-4-multi-agent-deep-research

# Optional model and budget overrides
AIM_CHAT_MODEL=gpt-5.4-mini
AIM_WRITER_MODEL=gpt-5.4-mini
AIM_SEARCH_DEPTH=advanced
AIM_SEARCH_CALL_LIMIT=3
AIM_EXTRACT_CALL_LIMIT=2
AIM_WORKER_MODEL_CALL_LIMIT=8
