# Auth/config for the Whiskers agent. Copy to `.env` and fill in.
# The agent process reads these; .env is gitignored — never commit real values.

# --- Option A: AWS Bedrock ---
# CLAUDE_CODE_USE_BEDROCK=1
# AWS_REGION=us-east-2
# Credentials: either an SSO/named profile...
# AWS_PROFILE=your-profile
# ...or explicit keys (uncomment instead of AWS_PROFILE):
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_SESSION_TOKEN=...

# --- Option B: Anthropic API directly (instead of Bedrock) ---
# Comment out the Bedrock lines above and set:
# ANTHROPIC_API_KEY=sk-ant-...

# --- Optional: override the model ---
# WHISKERS_MODEL=us.anthropic.claude-opus-4-8[1m]
