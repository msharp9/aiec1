# Copy this file to .env and fill in your keys.
# .env is gitignored so your secrets won't be committed.

# API keys
AI_GATEWAY_API_KEY="your-key"
LANGSMITH_API_KEY="your-key"
LANGSMITH_TRACING=true

# Model and budget overrides
AIM_GENERATOR_MODEL="openai/gpt-5.4-mini"
AIM_RAG_MODEL="openai/gpt-5.4-mini"
AIM_JUDGE_MODEL="openai/gpt-5.4-mini"
AIM_EMBEDDING_MODEL="openai/text-embedding-3-small"
AIM_TESTSET_SIZE=6
AIM_MAX_CONCURRENCY=2
